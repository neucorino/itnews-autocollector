# Add directories or file patterns to ignore during indexing (e.g. foo/ or *.csv)
.gitignore

.env

# データベースの永続化ファイル（AIに読ませるとインデックスが爆発します）
data/
*.db

# ログファイル（過去の実行ログをAIが読み込むと動作遅延の原因に）
logs/
*.log

# Docker関連（ビルド時の一時キャッシュなど）
.dockerignore

# Pythonの仮想環境（もしローカルに残っていれば）
.venv/
__pycache__/
*.pyc

# 開発環境固有の設定（CursorのAIの履歴など）
.cursor/